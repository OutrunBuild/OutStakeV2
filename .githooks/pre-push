#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# gate:fast runs targeted tests (only the test files mapped to the changed
# paths' rules), so a change that breaks an untouched/unmapped test file slips
# through. CI runs the full suite; gate:ci --all mirrors that locally so the
# push is blocked here (~12-15 min via_ir build + full forge test) instead of
# failing in CI after the push lands. pre-commit stays on gate:fast for a fast
# fmt/lint pre-check; the heavy full run is deferred to push.
npm run gate:ci -- --all
