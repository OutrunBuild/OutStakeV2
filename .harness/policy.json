{
  "version": 1,
  "repo": "OutStakeV2",
  "surfaces": {
    "solidity_prod": [
      "^src/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "solidity_test": [
      "^test/.*\\.sol$"
    ],
    "harness_control": [
      "^AGENTS\\.md$",
      "^README\\.md$",
      "^CLAUDE\\.md$",
      "^package\\.json$",
      "^\\.gitignore$",
      "^\\.solhintignore$",
      "^\\.github/workflows/.*$",
      "^\\.github/pull_request_template\\.md$",
      "^\\.github/workflows/pr-template-check\\.yml$",
      "^\\.githooks/.*$",
      "^script/harness/.*$",
      "^\\.harness/policy\\.json$",
      "^\\.harness/runtime/main-session-contract\\.md$",
      "^\\.harness/schemas/.*$",
      "^\\.claude/settings\\.json$",
      "^\\.claude/agents/.*$",
      "^\\.codex/agents/.*$",
      "^docs/ARCHITECTURE\\.md$",
      "^docs/TRACEABILITY\\.md$",
      "^docs/VERIFICATION\\.md$",
      "^docs/GLOSSARY\\.md$",
      "^docs/SECURITY_AND_APPROVALS\\.md$",
      "^docs/deployment\\.md$",
      "^docs/implementation-map\\.md$",
      "^docs/testing-and-evidence\\.md$",
      "(^|.*/)(spec|specs)/.*\\.(md|mdx)$",
      "^solhint.*\\.config\\.js$",
      "^foundry\\.toml$",
      "^remappings\\.txt$",
      "^package-lock\\.json$",
      "^npm-shrinkwrap\\.json$"
    ]
  },
  "write_roles": {
    "solidity_prod": "solidity-implementer",
    "solidity_test": "solidity-implementer",
    "harness_control": "process-implementer"
  },
  "risk_rules": {
    "high_risk_paths": [
      "^src/assets/.*\\.sol$",
      "^src/position/.*\\.sol$",
      "^src/yield/.*\\.sol$",
      "^src/router/.*\\.sol$",
      "^src/integrations/.*\\.sol$",
      "^src/libraries/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "high_risk_tokens": [
      "\\bdelegatecall\\b",
      "\\bselfdestruct\\b",
      "\\bassembly\\b",
      "\\bcallcode\\b"
    ],
    "slither_filter_paths": "lib|test|script|node_modules",
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions"
  },
  "review_matrix": {
    "non-semantic": [],
    "test-semantic": [
      "logic-reviewer"
    ],
    "prod-semantic": [
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer"
    ],
    "high-risk": [
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer"
    ]
  },
  "review_triggers": [
    {
      "id": "spec-doc-review",
      "reviewer_role": "spec-reviewer",
      "paths": [
        "(^|.*/)(spec|specs)/.*\\.(md|mdx)$"
      ],
      "surfaces": [
        "harness_control"
      ]
    }
  ],
  "security_test_writer_trigger": {
    "risk_tiers": ["high-risk"],
    "reviewer_finding_severity_to_activate": "critical"
  },
  "spec_readiness_gate": {
    "trigger_risk_tiers": ["prod-semantic", "high-risk"],
    "doc_exclusions": ["^docs/superpowers/"],
    "gate_action": "block",
    "required_reviewer": "spec-reviewer",
    "cross_cutting_trigger_threshold": 2,
    "cross_cutting_docs": [
      "docs/ARCHITECTURE.md",
      "docs/spec/access-control.md",
      "docs/spec/common-foundations.md",
      "docs/spec/protocol.md",
      "docs/GLOSSARY.md"
    ],
    "doc_mapping": {
      "assets": {
        "rules": [
          {
            "id": "assets-core",
            "check_docs": [
              "docs/spec/common-foundations.md",
              "docs/spec/protocol.md"
            ]
          }
        ]
      },
      "position": {
        "rules": [
          {
            "id": "position-core",
            "check_docs": [
              "docs/spec/position/state-machines.md",
              "docs/spec/position/accounting.md",
              "docs/spec/router/router-and-user-flows.md"
            ]
          }
        ]
      },
      "router": {
        "rules": [
          {
            "id": "router-core",
            "check_docs": [
              "docs/spec/router/router-and-user-flows.md",
              "docs/spec/position/state-machines.md"
            ]
          }
        ]
      },
      "yield": {
        "rules": [
          {
            "id": "yield-core",
            "check_docs": [
              "docs/spec/yield/yield-adapters.md",
              "docs/spec/yield/oracles-and-integrations.md",
              "docs/spec/router/router-and-user-flows.md"
            ]
          }
        ]
      }
    }
  },
  "remediation_policy": {
    "max_cycles": 5,
    "conflict_priority": ["security-reviewer", "gas-reviewer", "logic-reviewer"],
    "escalation": "user"
  },
  "verification_profiles": {
    "fast": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "targeted_tests",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "full": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "forge_test_full",
        "coverage_when_required",
        "slither_when_required",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "ci": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "forge_test_full",
        "coverage_when_required",
        "slither_when_required",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    }
  },
  "hard_blocks": [],
  "testing_gaps": {},
  "test_mapping": {
    "assets": {
      "tests": [
        "test/upgradeable/OutrunOFTUpgradeable.t.sol",
        "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "assets-core",
          "paths": [
            "^src/assets/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunOFTUpgradeable.t.sol",
            "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunOFTUpgradeable.t.sol",
            "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
          ]
        }
      ]
    },
    "position": {
      "tests": [
        "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
        "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol",
        "test/upgradeable/OutrunStakingPositionInvariantUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "position-core",
          "paths": [
            "^src/position/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
            "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
            "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol"
          ]
        }
      ]
    },
    "router": {
      "tests": [
        "test/upgradeable/OutrunRouterUpgradeable.t.sol",
        "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
        "test/upgradeable/RouterProxyIntegration.t.sol"
      ],
      "rules": [
        {
          "id": "router-core",
          "paths": [
            "^src/router/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunRouterUpgradeable.t.sol",
            "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
            "test/upgradeable/RouterProxyIntegration.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunRouterUpgradeable.t.sol",
            "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
            "test/upgradeable/RouterProxyIntegration.t.sol"
          ]
        }
      ]
    },
    "yield": {
      "tests": [
        "test/upgradeable/SYUpgradeable.t.sol",
        "test/upgradeable/SYAdaptersUpgradeable.t.sol",
        "test/upgradeable/SYAdaptersFork.t.sol",
        "test/upgradeable/OracleSetterUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "yield-core",
          "paths": [
            "^src/yield/.*\\.sol$",
            "^src/integrations/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/SYUpgradeable.t.sol",
            "test/upgradeable/SYAdaptersUpgradeable.t.sol",
            "test/upgradeable/OracleSetterUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/SYUpgradeable.t.sol",
            "test/upgradeable/SYAdaptersUpgradeable.t.sol",
            "test/upgradeable/OracleSetterUpgradeable.t.sol"
          ]
        }
      ]
    },
    "deployment": {
      "tests": [
        "test/deploy/OutstakeScriptUpgradeable.t.sol",
        "test/deploy/YieldDeployScriptUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "deployment-outstake-script",
          "paths": [
            "^script/deploy/OutstakeScript\\.s\\.sol$"
          ],
          "change_tests": [
            "test/deploy/OutstakeScriptUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/deploy/OutstakeScriptUpgradeable.t.sol"
          ]
        },
        {
          "id": "deployment-yield-deploy-script",
          "paths": [
            "^script/deploy/YieldDeployScript\\.s\\.sol$"
          ],
          "change_tests": [
            "test/deploy/YieldDeployScriptUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/deploy/YieldDeployScriptUpgradeable.t.sol"
          ]
        }
      ]
    },
    "security": {
      "tests": [
        "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "security-high-risk",
          "paths": [
            "^src/assets/.*\\.sol$",
            "^src/position/.*\\.sol$",
            "^src/yield/.*\\.sol$",
            "^src/router/.*\\.sol$",
            "^src/integrations/.*\\.sol$",
            "^src/libraries/.*\\.sol$",
            "^script/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
          ]
        }
      ]
    }
  }
}
