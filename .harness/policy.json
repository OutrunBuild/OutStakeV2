{
  "version": 1,
  "repo": "OutStakeV2",
  "surfaces": {
    "solidity_prod": [
      "^src/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "solidity_test": [
      "^test/.*\\.sol$"
    ],
    "harness_control": [
      "^AGENTS\\.md$",
      "^README\\.md$",
      "^CLAUDE\\.md$",
      "^package\\.json$",
      "^\\.gitignore$",
      "^\\.solhint\\.json$",
      "^\\.solhintignore$",
      "^\\.github/workflows/.*$",
      "^\\.github/pull_request_template\\.md$",
      "^\\.github/workflows/pr-template-check\\.yml$",
      "^\\.githooks/.*$",
      "^script/harness/.*$",
      "^\\.harness/policy\\.json$",
      "^\\.harness/runtime/main-session-contract\\.md$",
      "^\\.harness/schemas/.*$",
      "^\\.claude/settings\\.json$",
      "^\\.claude/agents/.*$",
      "^\\.codex/agents/.*$",
      "^docs/ARCHITECTURE\\.md$",
      "^docs/TRACEABILITY\\.md$",
      "^docs/VERIFICATION\\.md$",
      "^docs/GLOSSARY\\.md$",
      "^docs/SECURITY_AND_APPROVALS\\.md$",
      "^docs/deployment\\.md$",
      "^docs/implementation-map\\.md$",
      "^docs/testing-and-evidence\\.md$",
      "^docs/review/.*\\.md$",
      "^docs/.*$",
      "(^|.*/)(spec|specs)/.*\\.(md|mdx)$",
      "^solhint.*\\.config\\.js$",
      "^foundry\\.toml$",
      "^remappings\\.txt$",
      "^package-lock\\.json$",
      "^npm-shrinkwrap\\.json$"
    ]
  },
  "write_roles": {
    "solidity_prod": "solidity-implementer",
    "solidity_test": "solidity-implementer",
    "harness_control": "process-implementer"
  },
  "risk_rules": {
    "slither_filter_paths": "lib|test|script|node_modules",
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions"
  },
  "orchestration_profiles": {
    "direct": {
      "writer": "main-session",
      "reviewers": [],
      "verifier": "main-session",
      "verification_profile": "fast"
    },
    "direct-review": {
      "writer": "main-session",
      "reviewers": "orchestration-selected",
      "verifier": "main-session",
      "verification_profile": "fast"
    },
    "delegated": {
      "writer": "policy-selected",
      "reviewers": "delegated-selected",
      "verifier": "main-session",
      "verification_profile": "fast"
    },
    "full-review": {
      "writer": "policy-selected",
      "reviewers": "full-review-matrix",
      "verifier": "main-session",
      "verification_profile": "fast"
    },
    "full-subagent": {
      "writer": "policy-selected",
      "reviewers": "full-review-matrix",
      "verifier": "required-verifier-agent",
      "verification_profile": "selected"
    },
    "no-op": {
      "writer": "none",
      "reviewers": [],
      "verifier": "none",
      "verification_profile": "none"
    },
    "blocked": {
      "writer": "none",
      "reviewers": [],
      "verifier": "none",
      "verification_profile": "none"
    }
  },
  "orchestration_writer_rules": [
    {
      "id": "spec-doc",
      "paths": ["(^|.*/)(spec|specs)/.*\\.(md|mdx)$"],
      "writer": "process-implementer"
    },
    {
      "id": "spec-readiness-doc-update",
      "trigger": "spec-readiness-doc-update",
      "writer": "process-implementer"
    },
    {
      "id": "harness-control",
      "paths": ["^\\.harness/.*$", "^script/harness/.*$", "^\\.github/workflows/.*$", "^AGENTS\\.md$", "^CLAUDE\\.md$"],
      "writer": "process-implementer"
    },
    {
      "id": "repo-metadata",
      "paths": ["^package\\.json$", "^package-lock\\.json$", "^npm-shrinkwrap\\.json$"],
      "writer": "process-implementer"
    },
    {
      "id": "docs",
      "paths": ["^docs/.*$", "^README\\.md$"],
      "writer": "process-implementer"
    }
  ],
  "writer_conflict_policy": {
    "mixed_spec_and_code": "run spec/document workflow first, then classify code changes separately",
    "mixed_solidity_and_harness_control": "either split into separately classified units before editing or keep the task combined and require full-review minimum",
    "mixed_docs_and_solidity": "docs are harness_control; apply mixed_solidity_and_harness_control. Preserve spec-readiness ordering, and require full-review minimum if production Solidity semantic changes remain bundled with docs."
  },
  "orchestration_review_roles": {
    "no-op": [],
    "non-semantic": [],
    "test-semantic": ["logic-reviewer"],
    "prod-semantic-risk-analysis-passed": ["logic-reviewer"]
  },
  "delegated_review_rules": [
    {
      "id": "spec-path",
      "paths": ["(^|.*/)(spec|specs)/.*\\.(md|mdx)$"],
      "reviewers": ["spec-reviewer"],
      "requires_human_confirmation": true
    },
    {
      "id": "spec-readiness-doc-update",
      "trigger": "spec-readiness-doc-update",
      "reviewers": ["spec-reviewer"],
      "requires_human_confirmation": true
    },
    {
      "id": "harness-control",
      "paths": ["^\\.harness/.*$", "^script/harness/.*$", "^\\.github/workflows/.*$"],
      "reviewers": [],
      "requires_human_confirmation": false
    },
    {
      "id": "non-spec-doc",
      "paths": ["^docs/.*$"],
      "exclude_paths": ["(^|.*/)(spec|specs)/.*\\.(md|mdx)$"],
      "reviewers": [],
      "requires_human_confirmation": false
    }
  ],
  "full_review_matrix": {
    "no-op": [],
    "non-semantic": [],
    "test-semantic": ["logic-reviewer"],
    "prod-semantic": ["logic-reviewer", "security-reviewer", "gas-reviewer"]
  },
  "orchestration_rules": {
    "delegated_surface": "harness_control",
    "spec_paths": ["(^|.*/)(spec|specs)/.*\\.(md|mdx)$"],
    "scope_escalation": {
      "prod_solidity_max_files_before_full_review": 1,
      "prod_solidity_max_semantic_lines_before_full_review": 20
    },
    "main_session_risk_analysis_required_for": [
      "semantic production Solidity changes not structurally escalated"
    ],
    "surface_sensitivity": {
      "solidity_prod": "sensitive",
      "solidity_test": "normal",
      "harness_control": "normal"
    },
    "full_ci_command_gates": {
      "coverage_when_required": {
        "change_class": "prod-semantic",
        "surface_sensitivity": "sensitive"
      },
      "slither_when_required": {
        "change_class": "prod-semantic",
        "surface_sensitivity": "sensitive",
        "paths": ["^src/.*\\.sol$"]
      }
    }
  },
  "security_test_writer_trigger": {
    "change_class": "prod-semantic",
    "selected_review_roles_include": ["security-reviewer"],
    "reviewer_finding_severity_to_activate": "critical"
  },
  "spec_readiness_gate": {
    "trigger_change_classes": ["prod-semantic"],
    "doc_exclusions": ["^docs/superpowers/"],
    "gate_action": "block",
    "required_reviewer": "spec-reviewer",
    "no_spec_change_attestation": {
      "env_var": "NO_SPEC_CHANGE_ATTESTATION_FILE",
      "required_kind": "no-spec-change-attestation",
      "required_change_class": "prod-semantic",
      "required_assertions": {
        "refactor_only": true,
        "product_semantics_unchanged": true,
        "permissions_unchanged": true,
        "fund_flow_unchanged": true,
        "state_machine_unchanged": true,
        "storage_layout_unchanged": true,
        "abi_unchanged": true,
        "mapped_specs_remain_valid": true,
        "business_spec_update_required": false
      }
    },
    "cross_cutting_trigger_threshold": 2,
    "cross_cutting_docs": [
      "docs/ARCHITECTURE.md",
      "docs/spec/access-control.md",
      "docs/spec/common-foundations.md",
      "docs/spec/protocol.md",
      "docs/GLOSSARY.md"
    ],
    "doc_mapping": {
      "assets": {
        "rules": [
          {
            "id": "assets-core",
            "check_docs": [
              "docs/spec/common-foundations.md",
              "docs/spec/protocol.md"
            ]
          }
        ]
      },
      "position": {
        "rules": [
          {
            "id": "position-core",
            "check_docs": [
              "docs/spec/position/state-machines.md",
              "docs/spec/position/accounting.md",
              "docs/spec/router/router-and-user-flows.md"
            ]
          }
        ]
      },
      "router": {
        "rules": [
          {
            "id": "router-core",
            "check_docs": [
              "docs/spec/router/router-and-user-flows.md",
              "docs/spec/position/state-machines.md"
            ]
          }
        ]
      },
      "yield": {
        "rules": [
          {
            "id": "yield-core",
            "check_docs": [
              "docs/spec/yield/yield-adapters.md",
              "docs/spec/yield/oracles-and-integrations.md",
              "docs/spec/router/router-and-user-flows.md"
            ]
          }
        ]
      }
    }
  },
  "remediation_policy": {
    "max_cycles": 5,
    "conflict_priority": ["security-reviewer", "gas-reviewer", "logic-reviewer"],
    "escalation": "user"
  },
  "verification_profiles": {
    "fast": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "targeted_tests",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "full": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "forge_test_full",
        "coverage_when_required",
        "slither_when_required",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "ci": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "forge_test_full",
        "coverage_when_required",
        "slither_when_required",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    }
  },
  "hard_blocks": [],
  "testing_gaps": {},
  "test_mapping": {
    "assets": {
      "tests": [
        "test/upgradeable/OutrunOFTUpgradeable.t.sol",
        "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "assets-core",
          "paths": [
            "^src/assets/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunOFTUpgradeable.t.sol",
            "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunOFTUpgradeable.t.sol",
            "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
          ]
        }
      ]
    },
    "position": {
      "tests": [
        "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
        "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol",
        "test/upgradeable/OutrunStakingPositionInvariantUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "position-core",
          "paths": [
            "^src/position/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
            "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
            "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol"
          ]
        }
      ]
    },
    "router": {
      "tests": [
        "test/upgradeable/OutrunRouterUpgradeable.t.sol",
        "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
        "test/upgradeable/RouterProxyIntegration.t.sol"
      ],
      "rules": [
        {
          "id": "router-core",
          "paths": [
            "^src/router/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunRouterUpgradeable.t.sol",
            "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
            "test/upgradeable/RouterProxyIntegration.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunRouterUpgradeable.t.sol",
            "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
            "test/upgradeable/RouterProxyIntegration.t.sol"
          ]
        }
      ]
    },
    "yield": {
      "tests": [
        "test/upgradeable/SYUpgradeable.t.sol",
        "test/upgradeable/SYAdaptersUpgradeable.t.sol",
        "test/upgradeable/SYAdaptersFork.t.sol",
        "test/upgradeable/OracleSetterUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "yield-core",
          "paths": [
            "^src/yield/.*\\.sol$",
            "^src/integrations/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/SYUpgradeable.t.sol",
            "test/upgradeable/SYAdaptersUpgradeable.t.sol",
            "test/upgradeable/OracleSetterUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/SYUpgradeable.t.sol",
            "test/upgradeable/SYAdaptersUpgradeable.t.sol",
            "test/upgradeable/OracleSetterUpgradeable.t.sol"
          ]
        }
      ]
    },
    "deployment": {
      "tests": [
        "test/deploy/OutstakeScriptUpgradeable.t.sol",
        "test/deploy/YieldDeployScriptUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "deployment-outstake-script",
          "paths": [
            "^script/deploy/OutstakeScript\\.s\\.sol$"
          ],
          "change_tests": [
            "test/deploy/OutstakeScriptUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/deploy/OutstakeScriptUpgradeable.t.sol"
          ]
        },
        {
          "id": "deployment-yield-deploy-script",
          "paths": [
            "^script/deploy/YieldDeployScript\\.s\\.sol$"
          ],
          "change_tests": [
            "test/deploy/YieldDeployScriptUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/deploy/YieldDeployScriptUpgradeable.t.sol"
          ]
        }
      ]
    },
    "security": {
      "tests": [
        "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "security-sensitive-scope",
          "paths": [
            "^src/assets/.*\\.sol$",
            "^src/position/.*\\.sol$",
            "^src/yield/.*\\.sol$",
            "^src/router/.*\\.sol$",
            "^src/integrations/.*\\.sol$",
            "^src/libraries/.*\\.sol$",
            "^script/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
          ]
        }
      ]
    }
  }
}
