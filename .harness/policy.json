{
  "version": 1,
  "repo": "OutStakeV2",
  "surfaces": {
    "solidity_prod": [
      "^src/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "solidity_test": [
      "^test/.*\\.sol$"
    ],
    "harness_control": [
      "^AGENTS\\.md$",
      "^README\\.md$",
      "^CLAUDE\\.md$",
      "^package\\.json$",
      "^\\.gitignore$",
      "^\\.solhint\\.json$",
      "^\\.solhintignore$",
      "^\\.github/workflows/.*$",
      "^\\.github/pull_request_template\\.md$",
      "^\\.github/workflows/pr-template-check\\.yml$",
      "^\\.githooks/.*$",
      "^script/harness/.*$",
      "^\\.harness/policy\\.json$",
      "^\\.harness/runtime/main-session-contract\\.md$",
      "^\\.harness/schemas/.*$",
      "^\\.claude/settings\\.json$",
      "^\\.claude/agents/.*$",
      "^\\.codex/agents/.*$",
      "^docs/.*$",
      "(^|.*/)(spec|specs)/.*\\.(md|mdx)$",
      "^solhint.*\\.config\\.js$",
      "^foundry\\.toml$",
      "^remappings\\.txt$",
      "^package-lock\\.json$",
      "^npm-shrinkwrap\\.json$"
    ]
  },
  "write_roles": {
    "solidity_prod": "solidity-implementer",
    "solidity_test": "solidity-implementer",
    "harness_control": "process-implementer"
  },
  "risk_rules": {
    "slither_filter_paths": "lib|test|script|node_modules",
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions"
  },
  "orchestration_review_roles": {
    "no-op": [],
    "non-semantic": [],
    "test-semantic": ["logic-reviewer"],
    "prod-semantic-risk-analysis-passed": ["logic-reviewer"]
  },
  "delegated_review_rules": [
    {
      "id": "harness-control",
      "paths": ["^\\.harness/.*$", "^script/harness/.*$", "^\\.github/workflows/.*$"],
      "reviewers": [],
      "requires_human_confirmation": false
    },
    {
      "id": "non-spec-doc",
      "paths": ["^docs/.*$"],
      "exclude_paths": ["(^|.*/)(spec|specs)/.*\\.(md|mdx)$"],
      "reviewers": [],
      "requires_human_confirmation": false
    }
  ],
  "full_review_matrix": {
    "no-op": [],
    "non-semantic": [],
    "test-semantic": ["logic-reviewer"],
    "prod-semantic": ["logic-reviewer", "security-reviewer", "gas-reviewer"]
  },
  "orchestration_rules": {
    "spec_paths": ["(^|.*/)(spec|specs)/.*\\.(md|mdx)$"],
    "scope_escalation": {
      "prod_solidity_max_files_before_full_review": 1,
      "prod_solidity_max_semantic_lines_before_full_review": 20
    },
    "surface_sensitivity": {
      "solidity_prod": "sensitive",
      "solidity_test": "normal",
      "harness_control": "normal"
    }
  },
  "hard_blocks": [],
  "testing_gaps": {},
  "test_mapping": {
    "assets": {
      "tests": [
        "test/upgradeable/OutrunOFTUpgradeable.t.sol",
        "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "assets-core",
          "paths": [
            "^src/assets/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunOFTUpgradeable.t.sol",
            "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunOFTUpgradeable.t.sol",
            "test/upgradeable/OutrunUniversalAssetsUpgradeable.t.sol"
          ]
        }
      ]
    },
    "position": {
      "tests": [
        "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
        "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol",
        "test/upgradeable/OutrunStakingPositionInvariantUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "position-core",
          "paths": [
            "^src/position/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
            "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunStakingPositionUpgradeable.t.sol",
            "test/upgradeable/OutrunStakingPositionFuzzUpgradeable.t.sol"
          ]
        }
      ]
    },
    "router": {
      "tests": [
        "test/upgradeable/OutrunRouterUpgradeable.t.sol",
        "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
        "test/upgradeable/RouterProxyIntegration.t.sol"
      ],
      "rules": [
        {
          "id": "router-core",
          "paths": [
            "^src/router/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/OutrunRouterUpgradeable.t.sol",
            "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
            "test/upgradeable/RouterProxyIntegration.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/OutrunRouterUpgradeable.t.sol",
            "test/upgradeable/OutrunRouterFuzzUpgradeable.t.sol",
            "test/upgradeable/RouterProxyIntegration.t.sol"
          ]
        }
      ]
    },
    "yield": {
      "tests": [
        "test/upgradeable/SYUpgradeable.t.sol",
        "test/upgradeable/SYAdaptersUpgradeable.t.sol",
        "test/upgradeable/SYAdaptersFork.t.sol",
        "test/upgradeable/OracleSetterUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "yield-core",
          "paths": [
            "^src/yield/.*\\.sol$",
            "^src/integrations/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/SYUpgradeable.t.sol",
            "test/upgradeable/SYAdaptersUpgradeable.t.sol",
            "test/upgradeable/OracleSetterUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/SYUpgradeable.t.sol",
            "test/upgradeable/SYAdaptersUpgradeable.t.sol",
            "test/upgradeable/OracleSetterUpgradeable.t.sol"
          ]
        }
      ]
    },
    "deployment": {
      "tests": [
        "test/deploy/OutstakeScriptUpgradeable.t.sol",
        "test/deploy/YieldDeployScriptUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "deployment-outstake-script",
          "paths": [
            "^script/deploy/OutstakeScript\\.s\\.sol$"
          ],
          "change_tests": [
            "test/deploy/OutstakeScriptUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/deploy/OutstakeScriptUpgradeable.t.sol"
          ]
        },
        {
          "id": "deployment-yield-deploy-script",
          "paths": [
            "^script/deploy/YieldDeployScript\\.s\\.sol$"
          ],
          "change_tests": [
            "test/deploy/YieldDeployScriptUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/deploy/YieldDeployScriptUpgradeable.t.sol"
          ]
        }
      ]
    },
    "security": {
      "tests": [
        "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
      ],
      "rules": [
        {
          "id": "security-sensitive-scope",
          "paths": [
            "^src/assets/.*\\.sol$",
            "^src/position/.*\\.sol$",
            "^src/yield/.*\\.sol$",
            "^src/router/.*\\.sol$",
            "^src/integrations/.*\\.sol$",
            "^src/libraries/.*\\.sol$",
            "^script/.*\\.sol$"
          ],
          "change_tests": [
            "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
          ],
          "evidence_tests": [
            "test/upgradeable/AdversarialTestsUpgradeable.t.sol"
          ]
        }
      ]
    }
  },
  "verification_profiles": {
    "ci": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "forge_test_full",
        "coverage_when_required",
        "slither_when_required",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "fast": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "targeted_tests",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "full": {
      "required_commands": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "forge_test_full",
        "coverage_when_required",
        "slither_when_required",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    }
  }
}
