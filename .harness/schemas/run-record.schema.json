{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/skills/solidity-subagent-harness/schemas/run-record.schema.json",
  "title": "Solidity Subagent Harness Run Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "repo",
    "changed_files",
    "surface",
    "risk_tier",
    "writer_role",
    "review_roles",
    "verification_profile",
    "profile_required_commands",
    "commands_run",
    "command_results",
    "delegated_remediations",
    "blocking_findings",
    "residual_risks",
    "final_verdict"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "surface": {
      "oneOf": [
        {
          "const": "no-op"
        },
        {
          "type": "array",
          "items": {
            "$ref": "policy.schema.json#/$defs/surfaceName"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        {
          "$ref": "policy.schema.json#/$defs/surfaceName"
        }
      ]
    },
    "risk_tier": {
      "type": "string",
      "enum": [
        "none",
        "non-semantic",
        "test-semantic",
        "prod-semantic",
        "high-risk"
      ]
    },
    "writer_role": {
      "type": "string",
      "enum": [
        "none",
        "solidity-implementer",
        "process-implementer"
      ]
    },
    "review_roles": {
      "type": "array",
      "items": {
        "$ref": "policy.schema.json#/$defs/reviewRoleName"
      },
      "uniqueItems": true
    },
    "verification_profile": {
      "type": "string",
      "enum": [
        "none",
        "fast",
        "full",
        "ci"
      ]
    },
    "profile_required_commands": {
      "oneOf": [
        {
          "$ref": "#/$defs/noopRequiredCommands"
        },
        {
          "$ref": "policy.schema.json#/$defs/fastRequiredCommands"
        },
        {
          "$ref": "policy.schema.json#/$defs/fullRequiredCommands"
        }
      ]
    },
    "commands_run": {
      "$ref": "#/$defs/commandRunMap"
    },
    "command_results": {
      "$ref": "#/$defs/commandResultMap"
    },
    "delegated_remediations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/delegatedRemediation"
      }
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "final_verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked",
        "no-op"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "final_verdict": {
            "const": "pass"
          }
        }
      },
      "then": {
        "properties": {
          "command_results": {
            "$ref": "#/$defs/allPassedCommandResultMap"
          },
          "blocking_findings": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "final_verdict": {
            "const": "no-op"
          }
        }
      },
      "then": {
        "properties": {
          "surface": {
            "const": "no-op"
          },
          "risk_tier": {
            "const": "none"
          },
          "writer_role": {
            "const": "none"
          },
          "review_roles": {
            "maxItems": 0
          },
          "verification_profile": {
            "const": "none"
          },
          "profile_required_commands": {
            "$ref": "#/$defs/noopRequiredCommands"
          },
          "commands_run": {
            "maxProperties": 0
          },
          "command_results": {
            "maxProperties": 0
          },
          "delegated_remediations": {
            "maxItems": 0
          },
          "blocking_findings": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "writer_role": {
            "const": "none"
          }
        }
      },
      "then": {
        "properties": {
          "delegated_remediations": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "writer_role": {
            "const": "solidity-implementer"
          }
        }
      },
      "then": {
        "properties": {
          "delegated_remediations": {
            "items": {
              "properties": {
                "primary_writer_role": {
                  "const": "solidity-implementer"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "writer_role": {
            "const": "process-implementer"
          }
        }
      },
      "then": {
        "properties": {
          "delegated_remediations": {
            "items": {
              "properties": {
                "primary_writer_role": {
                  "const": "process-implementer"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verification_profile": {
            "const": "none"
          }
        }
      },
      "then": {
        "properties": {
          "surface": {
            "const": "no-op"
          },
          "changed_files": {
            "maxItems": 0
          },
          "risk_tier": {
            "const": "none"
          },
          "writer_role": {
            "const": "none"
          },
          "review_roles": {
            "maxItems": 0
          },
          "final_verdict": {
            "const": "no-op"
          },
          "profile_required_commands": {
            "$ref": "#/$defs/noopRequiredCommands"
          },
          "commands_run": {
            "maxProperties": 0
          },
          "command_results": {
            "maxProperties": 0
          },
          "delegated_remediations": {
            "maxItems": 0
          },
          "blocking_findings": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verification_profile": {
            "const": "fast"
          }
        }
      },
      "then": {
        "properties": {
          "profile_required_commands": {
            "$ref": "policy.schema.json#/$defs/fastRequiredCommands"
          },
          "commands_run": {
            "$ref": "#/$defs/fastRequiredCommandRuns"
          },
          "command_results": {
            "$ref": "#/$defs/fastRequiredCommandResults"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verification_profile": {
            "const": "full"
          }
        }
      },
      "then": {
        "properties": {
          "profile_required_commands": {
            "$ref": "policy.schema.json#/$defs/fullRequiredCommands"
          },
          "commands_run": {
            "$ref": "#/$defs/fullRequiredCommandRuns"
          },
          "command_results": {
            "$ref": "#/$defs/fullRequiredCommandResults"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verification_profile": {
            "const": "ci"
          }
        }
      },
      "then": {
        "properties": {
          "profile_required_commands": {
            "$ref": "policy.schema.json#/$defs/fullRequiredCommands"
          },
          "commands_run": {
            "$ref": "#/$defs/fullRequiredCommandRuns"
          },
          "command_results": {
            "$ref": "#/$defs/fullRequiredCommandResults"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegated_remediations": {
            "minItems": 1
          }
        }
      },
      "then": {
        "properties": {
          "surface": {
            "oneOf": [
              {
                "const": "solidity_test"
              },
              {
                "type": "array",
                "contains": {
                  "const": "solidity_test"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commands_run": {
            "required": [
              "fmt_changed_solidity"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "command_results": {
            "required": [
              "fmt_changed_solidity"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command_results": {
            "required": [
              "fmt_changed_solidity"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "commands_run": {
            "required": [
              "fmt_changed_solidity"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commands_run": {
            "required": [
              "lint_changed_solidity"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "command_results": {
            "required": [
              "lint_changed_solidity"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command_results": {
            "required": [
              "lint_changed_solidity"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "commands_run": {
            "required": [
              "lint_changed_solidity"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commands_run": {
            "required": [
              "forge_build"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "command_results": {
            "required": [
              "forge_build"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command_results": {
            "required": [
              "forge_build"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "commands_run": {
            "required": [
              "forge_build"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commands_run": {
            "required": [
              "targeted_tests"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "command_results": {
            "required": [
              "targeted_tests"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command_results": {
            "required": [
              "targeted_tests"
