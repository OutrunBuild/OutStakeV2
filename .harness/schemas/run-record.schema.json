  "$defs": {
    "noopRequiredCommands": {
      "type": "array",
      "maxItems": 0
    },
    "commandRun": {
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "commandResult": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped",
            "not-applicable"
          ]
        },
        "exit_code": {
          "type": "integer"
        },
        "summary": {
          "type": "string"
        },
        "attribution": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "executedCommandResult": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed"
          ]
        },
        "exit_code": {
          "type": "integer"
        },
        "summary": {
          "type": "string"
        },
        "attribution": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "passedCommandResult": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "const": "passed"
        },
        "exit_code": {
          "type": "integer"
        },
        "summary": {
          "type": "string"
        },
        "attribution": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "fastRequiredCommandRuns": {
      "type": "object",
      "required": [
        "fmt_changed_solidity",
        "lint_changed_solidity",
        "forge_build",
        "targeted_tests",
        "bash_syntax_changed_shell",
        "node_syntax_changed_js",
        "npm_ci_when_package_changes"
      ]
    },
    "fastRequiredCommandResults": {
