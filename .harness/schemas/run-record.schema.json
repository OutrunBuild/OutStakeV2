            ]
          }
        }
      },
      "then": {
        "properties": {
          "command_results": {
            "required": [
              "coverage_when_required"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command_results": {
            "required": [
              "coverage_when_required"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "commands_run": {
            "required": [
              "coverage_when_required"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commands_run": {
