            ]
          }
        }
      },
      "then": {
        "properties": {
          "command_results": {
            "required": [
              "forge_test_full"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command_results": {
            "required": [
              "forge_test_full"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "commands_run": {
            "required": [
              "forge_test_full"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commands_run": {
            "required": [
