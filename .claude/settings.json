{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Bash(forge build*)",
      "Bash(forge test*)",
      "Bash(forge fmt*)",
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git ls-files)",
      "Bash(git rev-parse *)",
      "Bash(git submodule *)",
      "Bash(bash ./script/harness/*)",
      "Bash(bash -n *)",
      "Bash(node --check *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
