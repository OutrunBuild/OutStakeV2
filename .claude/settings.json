{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(forge build*)",
      "Bash(forge test *)",
      "Bash(forge fmt *)",
      "Bash(forge coverage *)",
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git submodule *)",
      "Bash(bash ./script/process/*)",
      "Bash(node ./script/process/*)",
      "Bash(bash -n *)",
      "Bash(node --check *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
