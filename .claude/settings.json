{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Bash(forge build*)",
      "Bash(forge test*)",
      "Bash(forge fmt*)",
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git ls-files)",
      "Bash(git rev-parse *)",
      "Bash(git submodule *)",
      "Bash(bash ./script/harness/*)",
      "Bash(bash -n *)",
      "Bash(node --check *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(git restore *)",
      "Bash(git checkout *)",
      "Bash(git clean *)",
      "Bash(git stash drop*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./script/harness/pre-edit-check.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./script/harness/block-agent-worktree-isolation.sh"
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'OutStakeV2 禁用 EnterWorktree（默认建到 .claude/worktrees/）。worktree 用: git worktree add .worktrees/<name>' >&2; exit 2"
          }
        ]
      }
    ]
  }
}
