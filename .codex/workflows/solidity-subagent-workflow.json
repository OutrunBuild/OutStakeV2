{
  "version": 2,
  "project": {
    "name": "OutStakeV2",
    "type": "solidity",
    "toolchain": "foundry"
  },
  "dispatch_backend": {
    "type": "native-codex-subagents",
    "role_manifests": ".codex/agents/*.toml",
    "role_contracts": ".codex/agents/*.md",
    "notes": [
      "Dispatch is role-manifest based.",
      "Task Brief and Agent Report are required workflow artifacts."
    ]
  },
  "indexes": {
    "runtime": ".codex/runtime/subagent-runtime.json",
    "policy": "docs/process/policy.json",
    "workflow_doc": "docs/process/subagent-workflow.md"
  },
  "artifacts": {
    "task_brief_directory": "docs/task-briefs",
    "agent_report_directory": "docs/agent-reports",
    "task_brief_template": ".codex/templates/task-brief.md",
    "agent_report_template": ".codex/templates/agent-report.md",
    "agent_directory": ".codex/agents"
  },
  "roles": {
    "main_session_role": "main-orchestrator",
    "default_roles": [
      "solidity-implementer",
      "process-implementer",
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer",
      "verifier"
    ],
    "on_demand_roles": [
      "solidity-explorer",
      "security-test-writer"
    ]
  },
  "surfaces": [
    {
      "name": "src_solidity",
      "path_patterns": [
        "^src/.*\\.sol$"
      ],
      "default_writer_role": "solidity-implementer",
      "required_roles": [
        "logic-reviewer",
        "security-reviewer",
        "gas-reviewer",
        "verifier"
      ],
      "optional_roles": [
        "solidity-explorer",
        "security-test-writer"
      ]
    },
    {
      "name": "script_solidity",
      "path_patterns": [
        "^script/.*\\.sol$"
      ],
      "default_writer_role": "solidity-implementer",
      "required_roles": [
        "logic-reviewer",
        "security-reviewer",
        "gas-reviewer",
        "verifier"
      ],
      "optional_roles": [
        "solidity-explorer",
        "security-test-writer"
      ]
    },
    {
      "name": "test_solidity",
      "path_patterns": [
        "^test/.*\\.sol$"
      ],
      "default_writer_role": "solidity-implementer",
      "required_roles": [
        "logic-reviewer",
        "verifier"
      ],
      "optional_roles": [
        "security-reviewer",
        "security-test-writer"
      ]
    },
    {
      "name": "process_surface",
      "path_patterns": [
        "^script/process/.*$",
        "^docs/process/.*$",
        "^\\.codex/.*$",
        "^AGENTS\\.md$"
      ],
      "default_writer_role": "process-implementer",
      "required_roles": [
        "verifier"
      ],
      "optional_roles": []
    },
    {
      "name": "shell_surface",
      "path_patterns": [
        "^(script/.*\\.sh|\\.githooks/.*)$"
      ],
      "default_writer_role": "process-implementer",
      "required_roles": [
        "verifier"
      ],
      "optional_roles": []
    },
    {
      "name": "package_metadata",
      "path_patterns": [
        "^(package\\.json|package-lock\\.json)$"
      ],
      "default_writer_role": "process-implementer",
      "required_roles": [
        "verifier"
      ],
      "optional_roles": []
    }
  ],
  "artifact_chain": {
    "solidity": [
      "Task Brief",
      "Agent Report",
      "review note",
      "verifier evidence",
      "quality:gate",
      "CI"
    ],
    "process": [
      "Task Brief",
      "Agent Report",
      "verifier evidence",
      "docs:check",
      "process:selftest"
    ]
  },
  "agents": {
    "role_delta_brief_template": ".codex/templates/role-delta-brief.md",
    "follow_up_brief_template": ".codex/templates/follow-up-brief.md"
  },
  "change_classifier": {
    "entrypoint": "script/process/classify-change.js",
    "classes": [
      "non-semantic",
      "test-semantic",
      "prod-semantic",
      "high-risk"
    ],
    "role_matrix": {
      "non-semantic": {
        "required_roles": [
          "verifier"
        ],
        "optional_roles": [
          "logic-reviewer"
        ],
        "verifier_profile": "light"
      },
      "test-semantic": {
        "required_roles": [
          "logic-reviewer",
          "verifier"
        ],
        "optional_roles": [
          "security-reviewer",
          "security-test-writer"
        ],
        "verifier_profile": "light"
      },
      "prod-semantic": {
        "required_roles": [
          "logic-reviewer",
          "security-reviewer",
          "gas-reviewer",
          "verifier"
        ],
        "optional_roles": [
          "solidity-explorer",
          "security-test-writer"
        ],
        "verifier_profile": "full"
      },
      "high-risk": {
        "required_roles": [
          "logic-reviewer",
          "security-reviewer",
          "gas-reviewer",
          "verifier"
        ],
        "optional_roles": [
          "solidity-explorer",
          "security-test-writer"
        ],
        "verifier_profile": "full"
      }
    },
    "review_order": {
      "non-semantic": [
        "solidity-implementer",
        "codex review",
        "verifier"
      ],
      "test-semantic": [
        "solidity-implementer",
        "logic-reviewer",
        "codex review",
        "verifier"
      ],
      "prod-semantic": [
        "solidity-implementer",
        "logic-reviewer",
        "security-reviewer",
        "gas-reviewer",
        "codex review",
        "verifier"
      ],
      "high-risk": [
        "solidity-implementer",
        "logic-reviewer",
        "security-reviewer",
        "gas-reviewer",
        "codex review",
        "verifier"
      ]
    },
    "verifier_profiles": {
      "light": {
        "description": "Use for non-semantic and test-semantic Solidity changes; skip specialist review and heavy static-analysis/gas gates unless the classifier escalates.",
        "intended_for": [
          "non-semantic",
          "test-semantic"
        ]
      },
      "full": {
        "description": "Use for semantic production Solidity changes; require the full reviewer bundle and the complete finish gate.",
        "intended_for": [
          "prod-semantic",
          "high-risk"
        ]
      }
    }
  }
}
