  "agents": {
    "main_session_role": "main-orchestrator",
    "task_brief_directory": "docs/task-briefs",
    "agent_report_directory": "docs/agent-reports",
    "main_session_forbidden_write_patterns": [
      "^AGENTS\\.md$",
      "^docs/process/.*$",
      "^docs/reviews/(README|TEMPLATE)\\.md$",
      "^docs/agent-reports/README\\.md$",
      "^docs/task-briefs/README\\.md$",
      "^\\.codex/.*$",
      "^\\.github/.*$",
      "^\\.githooks/.*$",
      "^package\\.json$",
      "^package-lock\\.json$",
      "^\\.gitignore$",
      "^\\.solhint\\.json$",
      "^\\.solhintignore$",
      "^src/.*\\.sol$",
      "^test/.*\\.sol$",
      "^test/.*\\.t\\.sol$",
      "^script/.*\\.sol$",
      "^script/.*\\.sh$",
      "^script/process/.*$"
    ],
    "require_task_brief_before_write_patterns": [
      "^src/.*\\.sol$",
      "^test/.*\\.sol$",
      "^test/.*\\.t\\.sol$",
      "^script/.*\\.sol$",
      "^AGENTS\\.md$",
      "^docs/process/.*$",
      "^\\.codex/.*$",
      "^script/process/.*$",
      "^package\\.json$",
      "^package-lock\\.json$"
    ],
    "required_writer_for_patterns": {
      "^src/.*\\.sol$": "solidity-implementer",
      "^test/.*\\.sol$": "solidity-implementer",
      "^test/.*\\.t\\.sol$": "solidity-implementer",
      "^(AGENTS\\.md|README\\.md|docs/process/.*|docs/reviews/(TEMPLATE|README)\\.md|docs/task-briefs/README\\.md|docs/agent-reports/README\\.md|docs/(ARCHITECTURE|GLOSSARY|TRACEABILITY|VERIFICATION)\\.md|docs/spec/.*|docs/adr/.*|\\.github/.*|\\.codex/.*|\\.gitignore|\\.solhint\\.json|\\.solhintignore)$": "process-implementer",
      "^(script/.*\\.sh|\\.githooks/.*)$": "process-implementer",
      "^script/process/.*$": "process-implementer",
      "^package\\.json$": "process-implementer",
      "^package-lock\\.json$": "process-implementer",
      "^script/.*\\.sol$": "solidity-implementer"
    },
    "default_roles": [
      "solidity-implementer",
      "process-implementer",
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer",
      "verifier"
    ],
    "on_demand_roles": [
      "solidity-explorer",
      "security-test-writer"
    ],
    "task_brief_template": ".codex/templates/task-brief.md",
    "agent_report_template": ".codex/templates/agent-report.md",
    "agent_directory": ".codex/agents",
    "workflow_index": ".codex/workflows/solidity-subagent-workflow.json",
    "role_delta_brief_template": ".codex/templates/role-delta-brief.md",
    "follow_up_brief_template": ".codex/templates/follow-up-brief.md"
  },
  "solidity_review_note": {
    "required_fields": [
      "Task Brief path",
      "Agent Report path",
      "Implementation owner",
      "Writer dispatch confirmed",
      "Semantic dimensions reviewed",
      "Source-of-truth docs checked",
      "External facts checked",
      "Local control-flow facts checked",
      "Evidence chain complete",
      "Semantic alignment summary",
      "Logic review summary",
      "Logic residual risks",
      "Logic evidence source"
    ],
    "boolean_fields": [
      "Writer dispatch confirmed",
      "Evidence chain complete"
    ],
    "task_brief_field": "Task Brief path",
    "agent_report_field": "Agent Report path",
    "implementation_owner_field": "Implementation owner",
    "writer_dispatch_confirmed_field": "Writer dispatch confirmed",
    "semantic_dimensions_field": "Semantic dimensions reviewed",
    "source_of_truth_field": "Source-of-truth docs checked",
    "external_facts_field": "External facts checked",
    "local_control_flow_field": "Local control-flow facts checked",
    "evidence_chain_field": "Evidence chain complete",
    "semantic_alignment_summary_field": "Semantic alignment summary",
    "critical_assumptions_field": "Semantic alignment summary",
    "task_brief_semantic_dimensions_field": "Semantic review dimensions",
    "task_brief_source_of_truth_field": "Source-of-truth docs",
    "task_brief_external_sources_field": "External sources required",
    "task_brief_critical_assumptions_field": "Critical assumptions to prove or reject",
    "task_brief_files_in_scope_field": "Files in scope",
    "task_brief_default_writer_role_field": "Default writer role",
    "task_brief_write_permissions_field": "Write permissions",
    "semantic_sensitive_patterns": [
      "^src/assets/.*\\.sol$",
      "^src/position/.*\\.sol$",
      "^src/yield/.*\\.sol$",
      "^src/router/.*\\.sol$",
      "^src/integrations/.*\\.sol$",
      "^src/libraries/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "freshness_source_fields": [
      "Logic evidence source",
      "Security evidence source",
      "Gas evidence source",
      "Verification evidence source"
    ],
    "review_note_must_postdate_agent_report": true,
    "agent_report_must_postdate_changed_files": true,
    "task_brief_implementation_owner_field": "Implementation owner",
    "task_brief_required_roles_field": "Required roles",
    "task_brief_required_verifier_commands_field": "Required verifier commands",
    "task_brief_dispatch_backend_field": "Writer dispatch backend",
    "task_brief_dispatch_target_field": "Writer dispatch target",
    "codex_review_summary_field": "Codex review summary",
    "codex_review_evidence_field": "Codex review evidence source",
    "logic_review_summary_field": "Logic review summary",
    "logic_review_risks_field": "Logic residual risks",
    "logic_review_evidence_field": "Logic evidence source"
  },
  "solidity_expectations": {
    "method_internal_comments_required": true,
    "method_internal_comment_focus": [
      "non-obvious control flow",
      "state transitions",
      "amount or accounting calculations",
      "authorization assumptions",
      "external-call intent"
    ],
    "comment_style_rule": "Prefer concise explanatory comments and avoid line-by-line restatement",
    "minimum_test_dimensions": [
      "unit",
      "failure-path",
      "boundary-case"
    ],
    "high_risk_test_dimensions": [
      "fuzz",
      "invariant",
      "adversarial",
      "integration",
      "upgrade"
    ],
    "high_risk_triggers": [
      "accounting",
      "state-machine",
      "access-control",
      "fund-flow",
      "upgradeability",
      "external-integration"
    ],
    "coverage_rule": "Tests must justify behavior confidence and may not stop at happy-path-only coverage"
  },
  "coverage": {
    "default_lcov_path": "coverage/lcov.info",
    "include_pattern": "^src/.*\\.sol$",
    "line_threshold": 80,
    "function_threshold": 80,
    "groups": [
      {
        "name": "assets",
        "prefix": "src/assets/",
        "branch_threshold": 65
      },
      {
        "name": "position",
        "prefix": "src/position/",
        "branch_threshold": 65
      },
      {
        "name": "yield",
        "prefix": "src/yield/",
        "branch_threshold": 65
      },
      {
        "name": "router",
        "prefix": "src/router/",
        "branch_threshold": 60
      },
      {
        "name": "integrations",
        "prefix": "src/integrations/",
        "branch_threshold": 0
      },
      {
        "name": "libraries",
        "prefix": "src/libraries/",
        "branch_threshold": 65
      }
    ],
    "fallback_group": {
      "name": "other-src",
      "branch_threshold": 60
    }
  },
  "quality_gate": {
    "src_sol_pattern": "^src/.*\\.sol$",
    "test_tsol_pattern": "^test/.*\\.t\\.sol$",
    "test_sol_pattern": "^test/.*\\.sol$",
    "shell_pattern": "^(script/.*\\.sh|\\.githooks/.*)$",
    "process_surface_pattern": "^(AGENTS\\.md|docs/process/.*|\\.codex/.*|script/process/.*|\\.github/.*|\\.githooks/.*|README\\.md|docs/reviews/(README|TEMPLATE)\\.md|docs/task-briefs/README\\.md|docs/agent-reports/README\\.md|\\.solhint\\.json|\\.solhintignore)$",
    "process_js_pattern": "^script/process/.*\\.js$",
    "package_pattern": "^(package\\.json|package-lock\\.json)$",
    "docs_contract_pattern": "^(AGENTS\\.md|\\.gitignore|\\.solhint\\.json|\\.solhintignore|docs/process/.*|docs/reviews/TEMPLATE\\.md|docs/reviews/README\\.md|docs/task-briefs/README\\.md|docs/agent-reports/README\\.md|\\.githooks/.*|\\.github/pull_request_template\\.md|\\.github/workflows/.*|\\.codex/.*)$",
    "process_selftest_patterns": [
      "^script/process/.*$",
      "^docs/process/.*$",
      "^AGENTS\\.md$",
      "^package\\.json$",
      "^package-lock\\.json$",
      "^\\.codex/.*$"
    ],
    "review_note_directory": "docs/reviews",
    "slither_filter_paths": "lib|test|script|node_modules",
    "slither_exclude_detectors": "naming-convention,too-many-digits,unindexed-event-address,immutable-states,unimplemented-functions",
    "src_default_roles": [
      "solidity-implementer",
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer",
      "verifier"
    ],
    "src_optional_roles": [
      "solidity-explorer",
      "security-test-writer"
    ],
    "test_default_roles": [
      "solidity-implementer",
      "logic-reviewer",
      "verifier"
    ],
    "test_optional_roles": [
      "security-reviewer",
      "security-test-writer"
    ],
    "process_default_roles": [
      "process-implementer",
      "verifier"
    ],
    "shell_default_roles": [
      "process-implementer",
      "verifier"
    ],
    "package_default_roles": [
      "process-implementer",
      "verifier"
    ],
    "docs_contract_default_roles": [
      "process-implementer",
      "verifier"
    ],
    "hard_block_conditions": [
      "required_command_failed",
      "main_session_unauthorized_write_to_restricted_path",
      "missing_required_writer_dispatch_for_restricted_path",
      "missing_task_brief_before_solidity_write",
      "unauthorized_write_out_of_scope",
      "security_high_finding_open",
      "missing_security_or_gas_evidence_for_src_change",
      "coverage_threshold_not_met_for_solidity_or_test_change",
      "missing_semantic_alignment_evidence_for_semantic_sensitive_change",
      "confirmed_finding_missing_evidence_chain",
      "review_note_invalid_for_src_change"
    ],
    "soft_block_conditions": [
      "explained_non_critical_gas_regression",
      "deferrable_simplification",
      "non_blocking_docs_follow_up"
    ],
    "stale_evidence_remediation_command": "npm run stale-evidence:loop",
    "stale_evidence_exit_code": 2,
    "script_sol_pattern": "^script/.*\\.sol$",
    "script_default_roles": [
      "solidity-implementer",
      "logic-reviewer",
      "security-reviewer",
      "gas-reviewer",
      "verifier"
    ]
  },
  "workflow": {
    "workflow_index": ".codex/workflows/solidity-subagent-workflow.json",
    "runtime_index": ".codex/runtime/subagent-runtime.json",
    "dispatch_backend": {
      "type": "native-codex-subagents",
      "role_manifests": ".codex/agents/*.toml",
      "role_contracts": ".codex/agents/*.md",
      "repo_local_dispatch_helpers": []
    },
    "artifact_sequences": {
      "solidity": [
        "Task Brief",
        "Agent Report",
        "review note",
        "verifier evidence",
        "quality:gate",
        "CI"
      ],
      "process": [
        "Task Brief",
        "Agent Report",
        "verifier evidence",
        "docs:check",
        "process:selftest"
      ]
    }
  },
  "task_brief": {
    "required_fields": [
      "Goal",
      "Change type",
      "Files in scope",
      "Change classification",
      "Change classification rationale",
      "Out of scope",
      "Known facts",
      "Open questions / assumptions",
      "Risks to check",
      "Required roles",
      "Optional roles",
      "Verifier profile",
      "Default writer role",
      "Implementation owner",
      "Write permissions",
      "Writer dispatch backend",
      "Writer dispatch target",
      "Writer dispatch scope",
      "Non-goals",
      "Acceptance checks",
      "Required verifier commands",
      "Required artifacts",
      "Review note required",
      "Semantic review dimensions",
      "Source-of-truth docs",
      "External sources required",
      "Critical assumptions to prove or reject",
      "Required output fields",
      "Review note impact",
      "If blocked"
    ],
    "boolean_fields": [
      "Review note required"
    ],
    "implementation_owner_field": "Implementation owner",
    "dispatch_backend_field": "Writer dispatch backend",
    "dispatch_target_field": "Writer dispatch target",
    "dispatch_scope_field": "Writer dispatch scope",
    "required_roles_field": "Required roles",
    "required_verifier_commands_field": "Required verifier commands",
    "review_note_required_field": "Review note required",
    "files_in_scope_field": "Files in scope",
    "default_writer_role_field": "Default writer role",
    "write_permissions_field": "Write permissions",
    "change_classification_field": "Change classification",
    "verifier_profile_field": "Verifier profile"
  },
  "agent_report": {
    "required_fields": [
      "Role",
      "Summary",
      "Task Brief path",
      "Scope / ownership respected",
      "Files touched/reviewed",
      "Residual risks"
    ],
    "boolean_fields": [
      "Scope / ownership respected"
    ],
    "task_brief_field": "Task Brief path",
    "scope_respected_field": "Scope / ownership respected",
    "role_field": "Role",
    "files_field": "Files touched/reviewed"
  },
  "verifier": {
    "required_disciplines": [
      "identify-required-commands-before-execution",
      "check-task-brief-and-agent-report-chain",
      "check-review-note-when-required",
      "record-failure-attribution",
      "emit-independent-pass-fail-verdict",
      "run-codex-review-before-final-verdict"
    ],
    "failure_attribution_required": true,
    "independent_verdict_required": true,
    "surface_command_sets": {
      "src_solidity": [
        "npm run codex:review",
        "forge fmt --check",
        "bash ./script/process/check-natspec.sh",
        "forge build",
        "forge test -vvv",
        "bash ./script/process/check-coverage.sh",
        "bash ./script/process/check-slither.sh",
        "bash ./script/process/check-gas-report.sh",
        "bash ./script/process/check-solidity-review-note.sh",
        "npm run docs:check"
      ],
      "test_solidity": [
        "forge fmt --check",
        "forge build",
        "forge test -vvv",
        "bash ./script/process/check-coverage.sh"
      ],
      "process_surface": [
        "bash -n <changed-shell-scripts>",
        "node --check <changed-process-js>",
        "npm run docs:check",
        "npm run process:selftest"
      ],
      "package_metadata": [
        "npm ci",
        "npm run docs:check",
        "npm run process:selftest"
      ],
      "script_solidity": [
        "npm run codex:review",
        "forge fmt --check",
        "forge build",
        "forge test -vvv",
        "bash ./script/process/check-solidity-review-note.sh",
        "npm run docs:check"
      ]
    },
    "codex_review": {
      "wrapper_command": "npm run codex:review",
      "cli_equivalent": "codex review --uncommitted",
      "task_brief_token": "npm run codex:review",
      "command_tokens": [
        "npm run codex:review",
        "bash ./script/process/run-codex-review.sh",
        "codex review --uncommitted",
        "codex review"
      ],
      "summary_field": "Codex review summary",
      "evidence_field": "Codex review evidence source"
    },
    "local_codex_review": {
      "required_classifications": [
        "prod-semantic",
        "high-risk"
      ],
      "force_env": "FORCE_CODEX_REVIEW"
    },
    "profiles": {
      "light": {
        "description": "Use for non-semantic and test-semantic Solidity changes; skip specialist review and heavy static-analysis/gas gates unless the classifier escalates.",
        "intended_for": [
          "non-semantic",
          "test-semantic"
        ]
      },
      "full": {
        "description": "Use for semantic production Solidity changes; require the full reviewer bundle and the complete finish gate.",
        "intended_for": [
          "prod-semantic",
          "high-risk"
        ]
      }
    }
  },
  "change_classifier": {
    "entrypoint": "script/process/classify-change.js",
    "classifications": [
      "non-semantic",
      "test-semantic",
      "prod-semantic",
      "high-risk"
    ],
    "high_risk_path_patterns": [
      "^src/(router|position|yield|vault|lending|loan|oracle|oracles|integrations|markets|core|pool|pol|assets)/.*\\.sol$",
      "^src/libraries/.*\\.sol$",
      "^script/.*\\.sol$"
    ],
    "high_risk_token_patterns": [
      "\\b(delegatecall|call\\(|staticcall|safeTransfer|transferFrom|approve|permit|mint|burn|deposit|withdraw|redeem|borrow|repay|liquidat|oracle|price|reward|fee|claim|settle|swap|rebalance|owner|admin|guardian|role|upgrade|initialize|share|asset|balance)\\b"
    ],
    "role_matrix": {
      "non-semantic": {
        "required_roles": [
          "verifier"
        ],
        "optional_roles": [
          "logic-reviewer"
        ],
        "verifier_profile": "light"
      },
      "test-semantic": {
        "required_roles": [
          "logic-reviewer",
          "verifier"
        ],
        "optional_roles": [
          "security-reviewer",
          "security-test-writer"
        ],
        "verifier_profile": "light"
      },
      "prod-semantic": {
        "required_roles": [
          "logic-reviewer",
          "security-reviewer",
          "gas-reviewer",
          "verifier"
        ],
        "optional_roles": [
          "solidity-explorer",
          "security-test-writer"
        ],
        "verifier_profile": "full"
      },
      "high-risk": {
        "required_roles": [
          "logic-reviewer",
          "security-reviewer",
          "gas-reviewer",
          "verifier"
        ],
        "optional_roles": [
          "solidity-explorer",
          "security-test-writer"
        ],
        "verifier_profile": "full"
      }
    },
    "verifier_profiles": {
      "light": {
        "description": "Use for non-semantic and test-semantic Solidity changes; skip specialist review and heavy static-analysis/gas gates unless the classifier escalates.",
        "intended_for": [
          "non-semantic",
          "test-semantic"
        ]
      },
      "full": {
        "description": "Use for semantic production Solidity changes; require the full reviewer bundle and the complete finish gate.",
        "intended_for": [
          "prod-semantic",
          "high-risk"
        ]
      }
    }
  }
}
